# ── Supabase (get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api) ──
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# ── Set the following in Netlify Dashboard → Site Settings → Environment Variables ──

# Supabase service role key (server-side only, never expose to browser)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key

# Stripe (get from: https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...  # from: Stripe Dashboard → Webhooks → your endpoint

# Gmail (buttonsandleis@gmail.com — requires App Password)
# Enable 2FA, then: Google Account → Security → App Passwords → generate
GMAIL_FROM=buttonsandleis@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Admin secret for send-status-email function (make up a random string)
ADMIN_SECRET=change-this-to-something-random
